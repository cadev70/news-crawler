            },
            {
                "name": "Bleacher Report NBA",
                "url": "https://bleacherreport.com/nba",
                "type": "html",
                "selectors": {
                    "article": "a[href*='/articles/'], div[class*='MuiCard-root'], div[class*='MuiPaper-root']",
                    "title": "h2, h3",
                    "link": "a[href*='/articles/']",
                    "content": "p, span",
                    "date": "[class*='Meta'], span"
                }
            },
            {
                "name": "The Athletic NBA",
                "url": "https://www.nytimes.com/athletic/nba/",
                "type": "html",
                "selectors": {
                    "article": "a[href*='/athletic/nba/']",
                    "title": "h2, h3, h4, p[class*='Typography'], [class*='headline']",
                    "link": "a[href*='/athletic/nba/']",
                    "content": "p:not([class*='Meta']), [class*='description'], [class*='summary']",
                    "date": "time, [class*='time']"
                }
            },
            {
                "name": "ClutchPoints NBA",
                "url": "https://clutchpoints.com/nba/",
                "type": "rss",
                "feedUrl": "https://clutchpoints.com/nba/feed"
            }
        ]
