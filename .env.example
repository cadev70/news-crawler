# Environment Variables for Basketball News Crawler

# Twitter/X API (optional - for API-based crawling)
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_BEARER_TOKEN=your_bearer_token

# Instagram (optional - for authenticated requests)
# INSTAGRAM_SESSION_ID=your_session_id

# Proxy (optional - for avoiding rate limits)
# HTTP_PROXY=http://proxy:port
# HTTPS_PROXY=https://proxy:port

# Logging
LOG_LEVEL=info

# Database
DB_PATH=data/db.json
